+			{
+
+			zeroFract = Max_real64 (zeroFract, maxBlackLevel / whiteLevel);
+
+			}
+
+		}
+
+	zeroFract = Min_real64 (zeroFract, kMaxStage3BlackLevelNormalized);
+
+	uint16 dstBlackLevel = (uint16) Round_uint32 (65535.0 * zeroFract);
