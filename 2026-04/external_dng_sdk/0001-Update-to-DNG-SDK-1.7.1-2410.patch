+		{
+
+		// If we have a mosaic image that supports non-zero black levels,
+		// enforce a minimum black level to give the demosaic algorithms
+		// some "footroom".
+
+		dstBlackLevel = (uint16) Max_uint32 (dstBlackLevel, 0x0404);
+
+		}
+	
+	return dstBlackLevel;
+
+	}
